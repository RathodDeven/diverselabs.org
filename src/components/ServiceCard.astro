---
export interface Props {
  title: string;
  description: string;
  features: string[];
  iconPath: string;
}

const { title, description, features, iconPath } = Astro.props;
---

<div class="surface-card p-6 md:p-8 rounded-xl transition-all group hover:-translate-y-0.5">
  <div class="w-14 h-14 icon-surface rounded-lg mb-5 transition-all flex items-center justify-center">
    <svg class="w-7 h-7 text-white/90" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d={iconPath}></path>
    </svg>
  </div>
  <h3 class="text-white font-bold text-lg mb-3 group-hover:text-white transition-colors">{title}</h3>
  <p class="text-text-secondary mb-5 leading-relaxed">{description}</p>
  <ul class="text-text-tertiary text-sm space-y-2">
    {features.map((feature) => (
      <li class="flex items-start gap-2">
        <span class="text-white/40 mt-0.5">•</span>
        <span>{feature}</span>
      </li>
    ))}
  </ul>
</div>
